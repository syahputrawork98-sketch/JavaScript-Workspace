{
  "name": "javascript-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "corepack pnpm --filter web dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "db:generate": "corepack pnpm --filter @javascript-workspace/db prisma:generate",
    "db:migrate": "corepack pnpm --filter @javascript-workspace/db prisma:migrate",
    "db:studio": "corepack pnpm --filter @javascript-workspace/db prisma:studio"
  }
}
